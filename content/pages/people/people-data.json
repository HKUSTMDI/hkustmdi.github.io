  "en": {
    "leader": {
      "name": "Prof. Lei Chen",
      "position": "Chair Professor, Dean of Information Hub",
      "avatar": "/static/website/images/people/LeiChen.jpg",
      "introduction": "Lei Chen holds a Ph.D. in Computer Science from the University of Waterloo, Canada. He is currently the Dean of the Information Hub at the Hong Kong University of Science and Technology (Guangzhou), Chair Professor in the Data Science and Analytics Thrust, Director of the HKUST Big Data Institute, and Director of the Ministry of Education/MSRA Key Laboratory of Information Technology at HKUST. Professor Chen has received prestigious awards such as the 2020 China Electronic Society Science and Technology First Prize, the 2015 ACM SIGMOD Test of Time Award, the 2022 VLDB Best Research Paper Award, and the 2014 VLDB Distinguished Demonstration Award. He served as the co-chair of the VLDB 2019 PC. Currently, Professor Chen is the Editor-in-Chief of IEEE TKDE. He is a Changjiang Chair Professor, NSFC Overseas Outstanding Young Scientist, IEEE Fellow & ACM Fellow, ACM Distinguished Scientist, and the VLDB Endowment President.",
      "achievements": []
    },
